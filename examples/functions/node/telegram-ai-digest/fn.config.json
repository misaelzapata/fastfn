{
  "timeout_ms": 20000,
  "invoke": {
    "summary": "Scheduled Telegram digest (weather + news) with AI",
    "methods": ["GET", "POST"],
    "query": {"chat_id": "123"},
    "content_type": "application/json"
  },
  "schedule": {
    "enabled": false,
    "every_seconds": 60,
    "method": "GET",
    "query": {
      "dry_run": "false",
      "min_interval_secs": "60",
      "include_ai": "false"
    },
    "context": {
      "type": "cron"
    }
  }
}
