      10   local content_type = trim(invoke_meta.content_type)
      10   if content_type == "" then
       1     content_type = "application/json"
           end
      10   local normalized = string.lower(content_type)

      10   if normalized:find("application/json", 1, true) then
       7     local parsed = decode_json_string_if_possible(body_example)
       7     local schema = schema_from_value(parsed)
       7     return {
               required = false,
       7       content = {
       7         ["application/json"] = {
       7           schema = schema,
       7           examples = {
       7             primary = { value = parsed },
       7           },
       7         },
       7       },
       7     }
           end

       3   local body_text = body_example
       3   if type(body_text) ~= "string" then
       2     local encoded = cjson.encode(body_text)
       2     if type(encoded) == "string" then
       1       body_text = encoded
             else
       1       body_text = tostring(body_text)
             end
           end

       3   return {
             required = false,
       3     content = {
       3       [content_type] = {
       3         schema = { type = "string" },
       3         examples = {
       3           primary = { value = body_text },
       3         },
       3       },
       3     },
       3   }
         end

         local function operation_template(runtime, name, version, method, path_parameters, invoke_meta)
       9   local method_upper = string.upper(method)
       9   local label = runtime .. "/" .. name
       9   if version then
       1     label = label .. "@" .. version
           end

       9   local summary = method_upper .. " invoke " .. label
      12   if type(invoke_meta) == "table" and type(invoke_meta.summary) == "string" and trim(invoke_meta.summary) ~= "" then
       6     summary = method_upper .. " " .. trim(invoke_meta.summary)
           end

       9   local op = {
       9     tags = { "functions" },
       9     summary = summary,
       9     operationId = (method .. "_" .. runtime .. "_" .. name .. "_" .. (version or "default")):gsub("[^%w_]", "_"),
       9     responses = {
      18       ["200"] = success_response(),
      18       ["405"] = base_error_response("Method not allowed"),
      18       ["404"] = base_error_response("Unknown function or version"),
      18       ["413"] = base_error_response("Payload too large"),
      18       ["429"] = base_error_response("Concurrency limit exceeded"),
      18       ["502"] = base_error_response("Invalid runtime response"),
      18       ["503"] = base_error_response("Function runtime unavailable"),
      18       ["504"] = base_error_response("Runtime timeout"),
       9     },
           }

      18   op.requestBody = build_request_body(method, invoke_meta)

       9   if type(path_parameters) == "table" and #path_parameters > 0 then
       8     op.parameters = clone_path_parameters(path_parameters)
           end
       9   append_query_parameters(op, invoke_meta)

       9   return op
         end

         local function normalized_methods(methods)
       7   return invoke_rules.normalized_methods(methods, DEFAULT_METHODS)
         end

         local function mapped_route_entries(raw_entry)
       9   if type(raw_entry) ~= "table" then
       1     return {}
           end

           -- Backward-compatible shape: { runtime=..., fn_name=..., version=..., methods=... }
       8   if raw_entry.runtime ~= nil or raw_entry.fn_name ~= nil or raw_entry.version ~= nil or raw_entry.methods ~= nil then
       2     return { raw_entry }
           end

           -- Current shape: array of route entries (one entry per target/method set).
       6   local out = {}
      14   for _, item in ipairs(raw_entry) do
       8     if type(item) == "table" then
       7       out[#out + 1] = item
             end
           end
       6   return out
         end

         local function route_to_openapi_path_and_parameters(route)
      11   local raw = tostring(route or "")
      11   if raw == "" then
       1     return nil, {}
           end
      10   if raw == "/" then
       1     return "/", {}
           end

       9   local segments = {}
       9   local path_parameters = {}
       9   local seen = {}
      32   for seg in raw:gmatch("[^/]+") do
      23     local name, catch_all = seg:match("^:([A-Za-z0-9_]+)(%*?)$")
      23     if name then
       4       segments[#segments + 1] = "{" .. name .. "}"
       4       if not seen[name] then
       4         seen[name] = true
       4         local p = {
       4           name = name,
                   ["in"] = "path",
                   required = true,
       4           schema = { type = "string" },
                 }
       4         if catch_all == "*" then
       1           p.description = "Catch-all path parameter; value may include '/' segments."
                 end
       4         path_parameters[#path_parameters + 1] = p
               end
      19     elseif seg == "*" then
       6       local wildcard_name = "wildcard"
       6       if seen[wildcard_name] then
       3         local i = 2
       8         while seen[wildcard_name .. tostring(i)] do
       1           i = i + 1
                 end
       6         wildcard_name = wildcard_name .. tostring(i)
               end
       6       seen[wildcard_name] = true
       6       segments[#segments + 1] = "{" .. wildcard_name .. "}"
       6       path_parameters[#path_parameters + 1] = {
       6         name = wildcard_name,
                 ["in"] = "path",
                 required = true,
       6         schema = { type = "string" },
                 description = "Catch-all path parameter; value may include '/' segments.",
       6       }
             else
      13       segments[#segments + 1] = seg
             end
           end

       9   if #segments == 0 then
       1     return "/", path_parameters
           end
       8   return "/" .. table.concat(segments, "/"), path_parameters
         end

       1 function M.build(catalog, opts)
       2   opts = opts or {}

       2   local server_url = opts.server_url or "http://localhost:8080"
       2   local title = opts.title or "fastfn API"
